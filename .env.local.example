# ── Gmail (bắt buộc để gửi email) ────────────────────────────────────────────
# Hướng dẫn lấy App Password:
# 1. Vào https://myaccount.google.com/security
# 2. Bật "Xác minh 2 bước"
# 3. Tìm "Mật khẩu ứng dụng" → Tạo mật khẩu cho "Mail"
# 4. Dán 16 ký tự vào đây (không có khoảng trắng)

GMAIL_USER=monetai.vn@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Supabase (để lưu tất cả đăng ký vào DB → Excel đầy đủ) ──────────────────
# Hướng dẫn:
# 1. Tạo tài khoản tại https://supabase.com (miễn phí)
# 2. Tạo project mới
# 3. Vào Settings → API → lấy Project URL và service_role key
# 4. Vào SQL Editor → chạy lệnh tạo bảng (xem file SUPABASE_SETUP.sql)

SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
